# ============================================================
# .gitignore — AdventureWorks DWH
# ============================================================

# ------------------------------------------------------------
# CREDENCIALES Y CONFIGURACIÓN DE CONEXIÓN
# Nunca subir strings de conexión ni contraseñas
# ------------------------------------------------------------
*.config
connection.ini
secrets.env
.env
credentials.json

# ------------------------------------------------------------
# ARCHIVOS TEMPORALES DE SSMS
# SQL Server Management Studio genera estos al trabajar
# ------------------------------------------------------------
*.suo
*.user
*.sqlproj.user
.vs/
*.tmp
*.temp

# ------------------------------------------------------------
# BACKUPS DE BASE DE DATOS
# Los .bak y .mdf pueden pesar varios GB
# ------------------------------------------------------------
*.bak
*.mdf
*.ldf
*.ndf

# ------------------------------------------------------------
# ARCHIVOS DE POWER BI

# ------------------------------------------------------------
*.pbix       

# ------------------------------------------------------------
# SISTEMA OPERATIVO — WINDOWS
# ------------------------------------------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# ------------------------------------------------------------
# EDITORES Y IDEs
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# LOGS Y REPORTES DE EJECUCIÓN LOCALES
# ------------------------------------------------------------
*.log
logs/
output/